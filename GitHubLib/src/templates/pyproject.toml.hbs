[build-system]
requires = ["setuptools>=68"]
build-backend = "setuptools.build_meta"

[project]
name = "worlds_{{slug}}"
version = "{{world_version}}"
description = "{{game}} world for MultiworldGG"
readme = "README.md"
requires-python = ">=3.10"
authors = [
  {{#each authors}}{ name = "{{this}}" }{{#unless @last}},{{/unless}}{{/each}}
]
license = "MIT"

[tool.setuptools.packages.find]
where = ["src"]
include = ["worlds*"]
namespaces = true
