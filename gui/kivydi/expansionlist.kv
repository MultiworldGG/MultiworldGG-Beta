<GameListPanel>:
    padding: dp(8),dp(4),dp(8),dp(4)
    id: game_item
    MDExpansionPanelHeader:
        padding: dp(8),0,dp(8),0
        radius: dp(8),0,dp(8),0
        id: panel_header
    MDExpansionPanelContent:
        id: panel_content
        orientation: 'vertical'
        y: 82
        padding: dp(12), 0, dp(12), dp(12)
        spacing: dp(8)
        MDLabel:
            adaptive_height: True
            padding: 0

<SlotListItemHeader>:
    id: slot_item_header
    spacing: dp(4)
    padding: dp(8),dp(4),dp(8),dp(4)
    orientation: "horizontal"
    height: dp(70)
    size_hint_y: None
    theme_bg_color: "Custom"
    md_bg_color: app.theme_cls.secondaryContainerColor
    MDListItemLeadingAvatar:
        width: dp(40)
        id: leading_avatar
        source: root.item_data['avatar']
        pos_hint: {"center_y": 0.5, "center_x": 0.5}
    MDBoxLayout:
        orientation: "vertical"
        size_hint_x: 1
        padding: 0,dp(10),0,dp(10)
        MDBoxLayout:
            id: slot_item_container
            orientation: "horizontal"
            size_hint_y: .5
            MDListItemHeadlineText:
                text: root.slot_name
                theme_text_color: "Custom"
                text_color: app.theme_cls.onSecondaryContainerColor
                pos_hint: {"center_y": 0.5}
        MDBoxLayout:
            id: game_item_container
            orientation: "horizontal"
            size_hint_y: .5
            MDListItemTertiaryText:
                text: root.item_data['game']
                theme_text_color: "Custom"
                pos_hint: {"center_y": 0.5}
                text_color: app.theme_cls.onSecondaryContainerColor
    GameTrailingPressedIconButton:
        width: dp(40)
        id: chevron
        icon: "gamepad-round-right"
        pos_hint: {"center_y": 0.5, "center_x": 0.5}
        on_release: root.panel.toggle_expansion(self)


<GameListItemHeader>:
    id: game_item_header
    spacing: dp(4)
    padding: dp(8),dp(4),dp(8),dp(4)
    height: dp(60)
    size_hint_y: None
    theme_bg_color: "Custom"
    md_bg_color: app.theme_cls.tertiaryContainerColor if self.state == "down" else app.theme_cls.secondaryContainerColor
    on_release: root.on_release(self, args)
    MDListItemLeadingAvatar:
        id: leading_avatar
        source: root.game_data['cover_url']
        width: dp(40)
        pos_hint: {"center_y": 0.5, "center_x": 0.5}
    MDListItemSupportingText:
        id: game_item_header_text
        text: root.game_data["game_name"]
        text_color: app.theme_cls.onSurfaceColor
        theme_text_color: "Custom"
        role: "medium"
        shorten: False
        pos_hint: {"center_y": 0.5, "center_x": 0.5}
    GameTrailingPressedIconButton:
        width: dp(40)
        id: chevron
        icon: "gamepad-round-right"
        pos_hint: {"center_y": 0.5, "center_x": 0.5}
        on_release: root.panel.toggle_expansion(self)

<ListItemTooltip>:
    MDTooltipPlain:
        text: root.tooltip_text
        do_wrap: True
        adaptive_height: True
        theme_text_color: "Custom"
        theme_bg_color: "Custom"
        md_bg_color: app.theme_cls.secondaryContainerColor
        text_color: app.theme_cls.onSecondaryContainerColor

<GameListItem>:
    tooltip_text: ""
    ripple_effect: False
    theme_elevation_level: "Custom"
    MDListItemLeadingIcon:
        icon: root.icon

<GameListItemLongText>:
    text: root.text
    size_hint_x: 1
    tooltip_text: root.tooltip_text
    shorten: False
    do_wrap: False
    adaptive_height: True
    role: "small"

<GameListItemShortText>:
    text: root.text
    size_hint_x: 1
    shorten: False
    do_wrap: False
    adaptive_height: True
    role: "small"    

<MWBaseListItem>:
    spacing: dp(8)
    padding: 12, 12, 12, 12
    orientation: "vertical"
    ripple_effect: False
    theme_shadow_color: "Custom"
    theme_bg_color: "Custom"
    md_bg_color: app.theme_cls.surfaceContainerColor
    theme_elevation_level: "Custom"

<SlotListItem>:
    id: slot_item
    height: dp(70)
    size_hint_y: None
    MDBoxLayout:
        id: slot_item_top_container
        orientation: "horizontal"
        spacing: dp(4)
        size_hint_y: .5
        MDListItemLeadingIcon:
            id: slot_icon_location
            icon: "sign-direction"
            pos_hint: {"center_y": 0.5}
        MDListItemSupportingText:
            id: slot_text_location
            text: root.location_name
            pos_hint: {"center_y": 0.5}
            do_wrap: False
            theme_text_color: "Custom"
            text_color: app.theme_cls.onSurfaceColor
    MDBoxLayout:
        id: slot_item_bottom_container
        orientation: "horizontal"
        spacing: dp(4)
        size_hint_y: .5
        MDListItemLeadingIcon:
            id: slot_icon_item
            icon: "treasure-chest"
            pos_hint: {"center_y": 0.5}
        MDListItemSupportingText:
            id: slot_text_item
            text: root.item_name
            pos_hint: {"center_y": 0.5}
            do_wrap: False
            theme_text_color: "Custom"
            text_color: app.theme_cls.onSurfaceColor
        MDListItemTrailingIcon:
            id: slot_icon_goal
            icon: "flag_checkered"
            pos_hint: {"center_y": 0.5}

<HintListItem>:
    id: hint_item
    height: dp(176)
    size_hint_y: None
    MDBoxLayout:
        orientation: "horizontal"
        adaptive_height: True
        MDIcon:
            icon: "treasure-chest"
            pos_hint: {"center_y": 0.5}
        MDLabel:
            text: root.item_name
            do_wrap: True
            theme_font_style: "Custom"
            font_style: "Body"
            role: "large"
            theme_text_color: "Custom"
            text_color: app.theme_cls.onSurfaceColor
        MDCheckbox:
            id: hint_item_checkbox
            pos_hint: {"right": 0.1, "center_y": 0.5}
            on_active: root.on_hide(root, self.active)
            checkbox_icon_normal: "eye"
            checkbox_icon_active: "eye-off"
    MDBoxLayout:
        orientation: "horizontal"
        adaptive_height: True
        MDIcon:
            icon: "sign-direction"
            pos_hint: {"center_y": 0.5}
        MDLabel:
            text: root.location_name
            do_wrap: True
            theme_font_style: "Custom"
            font_style: "Body"
            role: "medium"
            theme_text_color: "Custom"
            text_color: app.theme_cls.onSurfaceColor
    MDBoxLayout:
        id: hint_item_entrance_container
        orientation: "horizontal"
        adaptive_height: True
        MDIcon:
            icon: "door-open"
            pos_hint: {"center_y": 0.5}
        MDLabel:
            text: root.entrance_name
            do_wrap: True
            theme_font_style: "Custom"
            font_style: "Body"
            role: "medium"
            theme_text_color: "Custom"
            text_color: app.theme_cls.onSurfaceColor
    MDButton:
        id: hint_item_status_button
        on_release: root.open_dropdown()
        MDButtonIcon:
            icon: root.hint_icon_status
        MDButtonText:
            text: root.hint_status_text
            theme_text_color: "Custom"
            text_color: app.theme_cls.onSurfaceColor
            theme_font_style: "Custom"
            font_style: "Body"
            role: "large"
    MDSegmentedButton:
        multiselect: True
        size_hint_x: .4
        MDSegmentedButtonItem:
            on_active: root.on_bkmode(self)
            MDSegmentButtonIcon:
                icon: "food"
            MDSegmentButtonLabel:
                text: "BK Mode"
                tooltip_text: "This hint is blocking me or another player from playing."
        MDSegmentedButtonItem:
            on_active: root.on_goal(self)
            MDSegmentButtonIcon:
                icon: "flag_checkered"
            MDSegmentButtonLabel:
                text: "Goal Item"
                tooltip_text: "This is a goal related item, I need it only to finish the game."
        MDSegmentedButtonItem:
            on_active: root.on_shop(self)
            MDSegmentButtonIcon:
                icon: "shop"
            MDSegmentButtonLabel:
                text: "Shop Item"
                tooltip_text: "This is a shop related item."
            # MDBoxLayout:
            #     orientation: "horizontal"
            #     size_hint_y: None
            #     height: dp(40)
            #     MDLabel:
            #         text: "Hide"
            #     MDCheckbox:
            #         id: hint_item_checkbox
            #         pos_hint: {"center_y": 0.5}
            #         on_active: root.on_hide(self)

<IconBadge>:
    text: ""
    theme_font_style: "Custom"
    role: "large"
    font_style: "Icon"
    theme_font_size: "Custom"
    font_size: dp(11)
