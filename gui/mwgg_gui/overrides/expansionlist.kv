<GameListPanel>:
    padding: dp(8),dp(4),dp(8),dp(4)
    id: game_item
    MDExpansionPanelHeader:
        padding: dp(8),0,dp(8),0
        radius: dp(8),0,dp(8),0
        id: panel_header
    MDExpansionPanelContent:
        id: panel_content
        orientation: 'vertical'
        y: 82
        padding: dp(12), 0, dp(12), dp(12)
        spacing: dp(8)
        MDLabel:
            adaptive_height: True
            padding: 0

<SlotListItemHeader>:
    id: slot_item_header
    spacing: dp(4)
    padding: dp(8),dp(4),dp(8),dp(4)
    orientation: "horizontal"
    height: dp(70)
    size_hint_y: None
    theme_bg_color: "Custom"
    md_bg_color: app.theme_cls.secondaryContainerColor
    theme_shadow_color: "Custom"
    shadow_color: app.theme_cls.shadowColor
    theme_elevation_level: "Custom"
    elevation_level: 0
    search: False
    waiting: False
    MDListItemLeadingAvatar:
        width: dp(40)
        id: leading_avatar
        source: root.item_data['avatar']
        pos_hint: {"center_y": 0.5, "center_x": 0.5}
    MDBoxLayout:
        orientation: "vertical"
        size_hint_x: 1
        padding: 0,dp(10),0,dp(10)
        MDBoxLayout:
            id: slot_item_container
            orientation: "horizontal"
            size_hint_y: .5
            MDListItemHeadlineText:
                id: slot_item_name
                shorten: False
                do_wrap: True
                text: root.slot_name
                theme_text_color: "Custom"
                text_color: app.theme_cls.onSecondaryContainerColor
                pos_hint: {"center_y": 0.5}
        MDBoxLayout:
            id: game_item_container
            orientation: "horizontal"
            size_hint_y: .5
            MDListItemTertiaryText:
                id: slot_item_game
                shorten: False
                do_wrap: True
                text: root.item_data['game']
                theme_text_color: "Custom"
                pos_hint: {"center_y": 0.5}
                text_color: app.theme_cls.onSecondaryContainerColor
    GameTrailingPressedIconButton:
        width: dp(40)
        id: chevron
        icon: "gamepad-round-right"
        pos_hint: {"center_y": 0.5, "center_x": 0.5}
        on_release: root.panel.toggle_expansion(self)

<HintListItemHeader>:
    id: hint_item_header
    padding: dp(8),0,dp(8),0
    radius: dp(8),0,dp(8),0
    variable_height: True
    orientation: "horizontal"
    theme_bg_color: "Custom"
    md_bg_color: app.theme_cls.secondaryContainerColor
    MDListItemLeadingIcon:
        icon: root.hint_icon
        pos_hint: {"center_y": 0.5, "center_x": 0.5}
    MDListItemSupportingText:
        id: hint_item_header_text
        text: root.hint_text
        text_color: app.theme_cls.onSurfaceColor
        theme_text_color: "Custom"
        role: "small"
        shorten: False
        do_wrap: True
        pos_hint: {"center_y": 0.5, "center_x": 0.5}
    GameTrailingPressedIconButton:
        width: dp(40)
        id: chevron
        icon: "gamepad-round-right"
        pos_hint: {"center_y": 0.5, "center_x": 0.5}
        on_release: root.panel.toggle_expansion(self)

<GameListItemHeader>:
    id: game_item_header
    spacing: dp(4)
    padding: dp(8),dp(4),dp(8),dp(4)
    height: dp(60)
    size_hint_y: None
    theme_bg_color: "Custom"
    md_bg_color: app.theme_cls.tertiaryContainerColor if self.state == "down" else app.theme_cls.secondaryContainerColor
    on_release: root.on_release(self, args)
    MDListItemLeadingAvatar:
        id: leading_avatar
        source: root.game_data['cover_url']
        width: dp(40)
        pos_hint: {"center_y": 0.5, "center_x": 0.5}
    MDListItemSupportingText:
        id: game_item_header_text
        text: root.game_data["game_name"]
        text_color: app.theme_cls.onSurfaceColor
        theme_text_color: "Custom"
        role: "medium"
        shorten: False
        pos_hint: {"center_y": 0.5, "center_x": 0.5}
    GameTrailingPressedIconButton:
        width: dp(40)
        id: chevron
        icon: "gamepad-round-right"
        pos_hint: {"center_y": 0.5, "center_x": 0.5}
        on_release: root.panel.toggle_expansion(self)

<ListItemTooltip>:
    MDTooltipPlain:
        text: root.tooltip_text
        do_wrap: True
        adaptive_height: True
        theme_text_color: "Custom"
        theme_bg_color: "Custom"
        md_bg_color: app.theme_cls.secondaryContainerColor
        text_color: app.theme_cls.onSecondaryContainerColor

<GameListItem>:
    tooltip_text: ""
    ripple_effect: False
    theme_elevation_level: "Custom"
    MDListItemLeadingIcon:
        icon: root.icon

<GameListItemLongText>:
    text: root.text
    size_hint_x: 1
    tooltip_text: root.tooltip_text
    shorten: False
    do_wrap: False
    adaptive_height: True
    role: "small"

<GameListItemShortText>:
    text: root.text
    size_hint_x: 1
    shorten: False
    do_wrap: False
    adaptive_height: True
    role: "small"    

<MWBaseListItem>:
    spacing: dp(8)
    padding: 12, 12, 12, 12
    orientation: "vertical"
    ripple_effect: False
    theme_shadow_color: "Custom"
    theme_bg_color: "Custom"
    md_bg_color: app.theme_cls.surfaceContainerColor
    theme_elevation_level: "Custom"

<SlotListItem>:
    id: slot_item
    entrance_texture: (0, 0)
    height: dp(70) # Default height because AAAAAAA
    my_item: False
    size_hint_y: None
    MDBoxLayout:
        id: slot_item_top_container
        orientation: "horizontal"
        spacing: dp(4)
        adaptive_height: True
        valign: "center"
        pos_hint: {"center_y": 0.5}
        MDListItemLeadingIcon:
            id: slot_icon_location
            icon: "sign-direction"
            pos_hint: {"center_y": 0.55}
        MDListItemSupportingText:
            id: slot_text_location
            text: root.location_name
            pos_hint: {"center_y": 0.5}
            shorten: False
            do_wrap: True
            theme_text_color: "Custom"
            text_color: app.theme_cls.onSurfaceColor
    MDBoxLayout:
        id: slot_item_bottom_container
        orientation: "horizontal"
        spacing: dp(4)
        adaptive_height: True
        valign: "center"
        pos_hint: {"center_y": 0.5}
        MDListItemLeadingIcon:
            id: slot_icon_item
            icon: "treasure-chest"
            pos_hint: {"center_y": 0.55}
        MDListItemSupportingText:
            id: slot_text_item
            text: root.item_name
            pos_hint: {"center_y": 0.5}
            do_wrap: True
            theme_text_color: "Custom"
            text_color: app.theme_cls.onSurfaceColor
        MDListItemTrailingIcon:
            id: slot_icon_goal
            icon: "flag_checkered"
            pos_hint: {"center_y": 0.5}

<HintListItem>:
    id: hint_item
    height: dp(30)
    size_hint_y: None
    hidden: False
    editable: False
    MDBoxLayout:
        spacing: dp(4)
        sort_key: 'player_name'
        MDBoxLayout:
            width: dp(20)
            height: dp(20)
            radius: dp(5)
            pos_hint: {"center_y": 0.5}
            FitImage:
                source: root.player_avatar
                radius: dp(5)
                fit_mode: 'contain'
        MDLabel:
            id: player
            text: root.player_name
            halign: 'center'
            valign: 'center'
            pos_hint: {"center_y": 0.5}
    MDBoxLayout:
        spacing: dp(4)
        sort_key: 'item_name'
        MDIcon:
            id: slot_icon_item
            icon: "treasure-chest"
            pos_hint: {"center_y": 0.5}
            IconBadge:
                id: slot_icon_item_badge
                text: root.item_badge_text
                opacity: 0 if not root.item_badge_text else 1
        MDLabel:
            id: slot_text_item
            text: root.item_name
            halign: 'center'
            valign: 'center'
            pos_hint: {"center_y": 0.5}
    MDBoxLayout:
        spacing: dp(4)
        sort_key: 'location_name'
        MDIcon:
            id: slot_icon_location
            icon: "sign-direction"
            pos_hint: {"center_y": 0.5}
            IconBadge:
                id: slot_icon_location_badge
                text: root.location_badge_text
                opacity: 0 if not root.location_badge_text else 1
        MDLabel:
            id: slot_text_location
            text: root.location_name
            halign: 'center'
            valign: 'center'
            pos_hint: {"center_y": 0.5}
    MDBoxLayout:
        spacing: dp(4)
        sort_key: 'entrance_name'
        MDIcon:
            id: slot_icon_entrance
            icon: "door-open"
            pos_hint: {"center_y": 0.5}
        MDLabel:
            id: slot_text_entrance
            text: root.entrance_name
            halign: 'center'
            valign: 'center'
            pos_hint: {"center_y": 0.5}
    MDRelativeLayout:
        id: slot_status
        sort_key: 'hint_status_text'
        halign: 'center'
        valign: 'center'
        pos_hint: {"center_y": 0.5}
        MDButton:
            pos_hint: {"center_y": 0.5}
            id: hint_item_status_button
            opacity: 1 if root.editable else 0
            disabled: not root.editable
            on_release: root.open_dropdown()
            MDButtonIcon:
                icon: root.hint_icon_status
            MDButtonText:
                text: root.hint_status_text
        MDBoxLayout:
            id: hint_item_status_container
            halign: 'center'
            valign: 'center'
            pos_hint: {"center_y": 0.5}
            opacity: 0 if root.editable else 1
            MDIcon:
                icon: root.hint_icon_status
            MDLabel:
                text: root.hint_status_text
    MDRelativeLayout:
        id: slot_mwgg_status
        halign: 'center'
        valign: 'center'
        spacing: dp(2)
        pos_hint: {"center_y": 0.5}
        MDBoxLayout:
            id: slot_mwgg_status_checkbox_container
            halign: 'center'
            valign: 'center'
            pos_hint: {"center_y": 0.5}
            opacity: 1 if root.editable else 0
            MDCheckbox:
                id: slot_mwgg_status_checkbox_bk
                checkbox_icon_normal: "food-off"
                checkbox_icon_down: "food"
                on_active: root.set_bkmode(root, self.active)
                pos_hint: {"center_y": 0.5}
            MDCheckbox:
                id: slot_mwgg_status_checkbox_goal
                checkbox_icon_normal: "flag_checkered-off"
                checkbox_icon_down: "flag_checkered"
                on_active: root.set_goal(root, self.active)
                pos_hint: {"center_y": 0.5}
            MDCheckbox:
                id: slot_mwgg_status_checkbox_shop
                checkbox_icon_normal: "shop-off"
                checkbox_icon_down: "shop"
                on_active: root.set_shop(root, self.active)
                pos_hint: {"center_y": 0.5}
        MDBoxLayout:
            id: slot_mwgg_status_icon_container
            halign: 'center'
            valign: 'center'
            pos_hint: {"center_y": 0.5}
            opacity: 1 if not root.editable else 0
            MDIcon:
                id: slot_mwgg_status_icon_bk
                icon: "food"
                pos_hint: {"center_y": 0.5}
            MDIcon:
                id: slot_mwgg_status_icon_goal
                icon: "flag_checkered"
                pos_hint: {"center_y": 0.5}
            MDIcon:
                id: slot_mwgg_status_icon_shop
                icon: "shop"
                pos_hint: {"center_y": 0.5}
    MDBoxLayout:
        id: hide
        halign: 'center'
        valign: 'center'
        pos_hint: {"center_y": 0.5}
        MDCheckbox:
            id: hide_checkbox
            pos_hint: {"center_y": 0.5}
            on_active: root.on_hide(root, self.active)
            checkbox_icon_down: "eye"
            checkbox_icon_normal: "eye-off"

<IconBadge>:
    text: ""
    theme_font_style: "Custom"
    role: "large"
    font_style: "Icon"
    theme_font_size: "Custom"
    font_size: dp(11)
