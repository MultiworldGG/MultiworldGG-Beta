# Operator: place Oliver's secret files here on the production host.
# This directory is bind-mounted into the Oliver container at /run/secrets:ro
# (see deploy/docker-compose.yml).
#
# Recommended files (any subset — only those referenced by OLIVER_*_FILE in
# oliver.env need to exist):
#   oliver_app_id            # one-line numeric App ID
#   oliver_private_key.pem   # full PEM, including BEGIN/END lines
#   oliver_webhook_secret    # one-line hex string from `openssl rand -hex 32`
#
# Set the directory to mode 0700 and own it appropriately on the host.
# Everything in this directory other than this .gitkeep is gitignored.
