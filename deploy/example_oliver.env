# Oliver-Multiworld-Squirrel env file (template).
# Operator: copy this to oliver.env (`cp example_oliver.env oliver.env`),
# `chmod 600 oliver.env`, then fill in the values below.
#
# Each secret can be supplied in EITHER of two ways — pick whichever you
# prefer per-secret. They are mutually exclusive (file wins if both are set).
#
#   1. Inline:    OLIVER_FOO=<literal value>
#   2. File path: OLIVER_FOO_FILE=/run/secrets/oliver_foo
#
# The file path is read inside the container — i.e. it must be a path that
# the Oliver container can see (volume-mounted from the host). The recommended
# layout is to put your secret files in a host directory and mount it as
# /run/secrets:ro in deploy/docker-compose.yml — see the commented `volumes:`
# block in that file.
#
# The PEM file in particular is awkward to embed inline (multi-line, escapes
# matter), so OLIVER_PRIVATE_KEY_FILE is the path of least resistance.

# ---- App ID --------------------------------------------------------------
# Numeric App ID from the GitHub App's General settings page.
# Inline:
OLIVER_APP_ID=
# OR file path:
# OLIVER_APP_ID_FILE=/run/secrets/oliver_app_id

# ---- Private key (PEM) ---------------------------------------------------
# Recommended: file path (the PEM is multi-line and ugly to inline).
# OLIVER_PRIVATE_KEY_FILE=/run/secrets/oliver_private_key.pem
#
# Inline alternative — wrap the entire PEM in double quotes and use literal
# \n in place of newlines:
#   OLIVER_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"
OLIVER_PRIVATE_KEY=

# ---- Webhook secret ------------------------------------------------------
# Webhook secret configured on the GitHub App. Generate with:
#   openssl rand -hex 32
# Inline:
OLIVER_WEBHOOK_SECRET=
# OR file path:
# OLIVER_WEBHOOK_SECRET_FILE=/run/secrets/oliver_webhook_secret

# ---- Index repo ----------------------------------------------------------
# Index repo Oliver opens PRs against. Default is lallaria/MultiworldGG-Index;
# override only for testing forks. Not a secret.
OLIVER_INDEX_REPO=lallaria/MultiworldGG-Index

# ---- Logging -------------------------------------------------------------
# Probot logging level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
